---
import '../styles/global.css';
const { title = 'DataCenterUpdate', description = 'Practical infrastructure insight for enterprise data center owners.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | DataCenterUpdate</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
</head>
<body>

<header>
  <a href="/" class="logo">
    <span class="logo-dc">DataCenter</span>
    <span class="logo-up">Update</span>
  </a>
  <nav>
    <a href="/articles">Articles</a>
    <a href="/topics">Topics</a>
    <a href="/about">About</a>
  </nav>
</header>

<main>
  <slot />
</main>

<footer>
  <span>AI/HPC infrastructure insight for enterprise data centers | Published by <a href="https://www.linkedin.com/in/michaeldecesare/" target="_blank" rel="noopener">Mike DeCesare</a></span>
  <span>datacenterupdate.com</span>
</footer>

</body>
</html>

<style>
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    border-bottom: 0.5px solid var(--color-border);
    background: var(--color-bg);
  }
  .logo { display: flex; flex-direction: column; line-height: 1; gap: 4px; text-decoration: none; }
  .logo-dc { font-size: 22px; font-weight: 600; letter-spacing: -0.02em; color: var(--color-text); }
  .logo-up { font-size: 11px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-amber); }
  nav { display: flex; gap: 1.75rem; }
  nav a { font-size: 13px; color: var(--color-muted); transition: color 0.15s; }
  nav a:hover { color: var(--color-text); }
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    border-top: 0.5px solid var(--color-border);
    font-size: 12px;
    color: var(--color-meta);
    background: var(--color-bg);
  }
  footer a {
    border-bottom: 0.5px solid var(--color-amber);
    color: var(--color-meta);
  }
  footer a:hover { color: var(--color-text); }
</style>
