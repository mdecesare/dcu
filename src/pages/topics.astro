---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sorted = allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const topics = [
  { id: 'power', label: 'Power', group: 'Core Infrastructure', desc: 'Capacity planning, power density, stranded capacity, and what your facility can actually deliver.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>` },
  { id: 'cooling', label: 'Cooling', group: 'Core Infrastructure', desc: 'Air, liquid, rear-door, direct-to-chip — what each approach actually requires before you commit.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/></svg>` },
  { id: 'ai-readiness', label: 'AI Readiness', group: 'Core Infrastructure', desc: 'What AI and HPC workloads demand from existing infrastructure, and how to assess whether you are ready.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="2" x2="9" y2="4"/><line x1="15" y1="2" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="22"/><line x1="15" y1="20" x2="15" y2="22"/><line x1="2" y1="9" x2="4" y2="9"/><line x1="2" y1="15" x2="4" y2="15"/><line x1="20" y1="9" x2="22" y2="9"/><line x1="20" y1="15" x2="22" y2="15"/></svg>` },
  { id: 'digital-twins', label: 'Digital Twins', group: 'Operations & Strategy', desc: 'Where digital twins add real value, where they are oversold, and what they cost to do properly.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="12" r="5"/><circle cx="16" cy="12" r="5"/></svg>` },
  { id: 'operations', label: 'Operations', group: 'Operations & Strategy', desc: 'Staffing, processes, and organizational readiness — the constraints that hardware decisions ignore.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="9" y1="7" x2="15" y2="7"/><line x1="9" y1="11" x2="15" y2="11"/><line x1="9" y1="15" x2="13" y2="15"/></svg>` },
  { id: 'strategy', label: 'Strategy', group: 'Operations & Strategy', desc: 'Build vs buy, colo vs owned, modernize vs migrate — the framework decisions that shape everything else.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/><line x1="5" y1="19" x2="19" y2="19"/></svg>` },
];
---
<Base title="Topics" description="Browse DataCenterUpdate articles by topic.">

  <div class="page-header">
    <h1>Topics</h1>
    <p>Six areas of focus — all practical, all vendor-neutral.</p>
  </div>

  {['Core Infrastructure', 'Operations & Strategy'].map(group => (
    <div class="group">
      <div class="group-label">{group}</div>
      {topics.filter(t => t.group === group).map(topic => {
        const articles = sorted.filter(a => a.data.topic === topic.id);
        return (
          <div class="topic-block" id={topic.id}>
            <div class="topic-header">
              <div class="topic-name">
                <span class="topic-icon" set:html={topic.icon} />
                {topic.label}
              </div>
              <div class="topic-desc">{topic.desc}</div>
            </div>
            {articles.length > 0 ? (
              <div class="topic-articles">
                {articles.slice(0, 3).map(article => (
                  <a href={`/articles/${article.slug}`} class="topic-article-row">
                    <span class="topic-article-title">{article.data.title}</span>
                    <span class="topic-article-meta">{article.data.type} · {article.data.readtime} min read</span>
                  </a>
                ))}
                {articles.length > 3 && (
                  <a href="/articles" class="see-all">See all {articles.length} articles &rarr;</a>
                )}
              </div>
            ) : (
              <div class="topic-empty">Articles coming soon.</div>
            )}
          </div>
        );
      })}
    </div>
  ))}

</Base>

<style>
  .page-header {
    padding: 2rem 2rem 1.5rem;
    border-bottom: 0.5px solid var(--color-border);
  }
  .page-header h1 { font-size: 22px; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 0.35rem; }
  .page-header p { font-size: 13px; color: var(--color-muted); }
  .group { border-bottom: 0.5px solid var(--color-border); }
  .group-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-amber);
    padding: 0.875rem 2rem 0;
  }
  .topic-block {
    display: grid;
    grid-template-columns: 280px 1fr;
    border-top: 0.5px solid var(--color-border);
    margin-top: 0.5rem;
  }
  .topic-block:first-of-type { border-top: none; margin-top: 0; }
  .topic-header { padding: 1.25rem 2rem; border-right: 0.5px solid var(--color-border); }
  .topic-name {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.4rem;
  }
  .topic-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--color-amber);
    display: flex;
    align-items: center;
  }
  .topic-icon svg { width: 18px; height: 18px; }
  .topic-desc { font-size: 12px; color: var(--color-muted); line-height: 1.55; }
  .topic-articles { padding: 0.75rem 1.5rem; }
  .topic-article-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 0.5px solid var(--color-border);
  }
  .topic-article-row:last-of-type { border-bottom: none; }
  .topic-article-row:hover .topic-article-title { color: var(--color-amber); }
  .topic-article-title { font-size: 13px; font-weight: 500; color: var(--color-text); line-height: 1.35; }
  .topic-article-meta { font-size: 11px; color: var(--color-meta); white-space: nowrap; }
  .topic-empty { padding: 1.25rem 1.5rem; font-size: 13px; color: var(--color-meta); font-style: italic; }
  .see-all { display: block; font-size: 12px; color: var(--color-amber); margin-top: 0.5rem; }
  .see-all:hover { text-decoration: underline; }
</style>
