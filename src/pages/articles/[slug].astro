---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
const { title, date, topic, type, readtime, summary } = article.data;

const topicLabel: Record<string, string> = {
  'power': 'Power',
  'cooling': 'Cooling',
  'ai-readiness': 'AI Readiness',
  'digital-twins': 'Digital Twins',
  'operations': 'Operations',
  'strategy': 'Strategy',
};

const formatted = new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={title} description={summary}>

  <article>
    <header>
      <div class="meta-top">
        <a href={`/topics#${topic}`} class="tag">{topicLabel[topic] || topic}</a>
        <span class="type">{type} · {readtime} min read</span>
      </div>
      <h1>{title}</h1>
      <p class="summary">{summary}</p>
      <div class="date">{formatted}</div>
    </header>

    <div class="body">
      <Content />
    </div>

    <div class="back">
      <a href="/articles">&larr; All articles</a>
    </div>
  </article>

</Base>

<style>
  article {
    max-width: 680px;
    margin: 0 auto;
    padding: 2.5rem 2rem 4rem;
  }
  header { margin-bottom: 2.5rem; border-bottom: 0.5px solid var(--color-border); padding-bottom: 1.5rem; }
  .meta-top { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
  .tag {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-amber);
  }
  .tag:hover { text-decoration: underline; }
  .type { font-size: 11px; color: var(--color-meta); }
  h1 {
    font-size: 28px;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }
  .summary {
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }
  .date { font-size: 12px; color: var(--color-meta); }
  .body {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text);
  }
  .body h2 { font-size: 20px; font-weight: 600; margin: 2rem 0 0.75rem; letter-spacing: -0.01em; }
  .body h3 { font-size: 17px; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  .body p { margin-bottom: 1.25rem; }
  .body ul, .body ol { margin: 0 0 1.25rem 1.5rem; }
  .body li { margin-bottom: 0.35rem; }
  .body blockquote {
    border-left: 3px solid var(--color-amber);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-muted);
    font-style: italic;
  }
  .back { margin-top: 3rem; padding-top: 1.5rem; border-top: 0.5px solid var(--color-border); }
  .back a { font-size: 13px; color: var(--color-muted); }
  .back a:hover { color: var(--color-amber); }
</style>
